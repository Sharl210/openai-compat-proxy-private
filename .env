# 应用名（可选）
APP_NAME=openai-compat-proxy

# 监听地址
LISTEN_ADDR=:21021

# 代理自身鉴权 key（可选）。
# 设置后，调用方需要带 Authorization: Bearer <proxy-key> / X-API-Key / Api-Key。
PROXY_API_KEY=050210

# provider 配置目录。
# 程序只会读取这个目录下的 *.env，不会读取 *.env.example。
# Cache_Info 的 provider 统计、聚合统计以及 v1默认分组统计也会写到这个目录下。
PROVIDERS_DIR=./providers

# 默认 provider overlay 列表。
# 支持单个 provider id，也支持用逗号分隔多个 provider id，例如 openai,azure。
# 越靠后的 provider 优先级越高；未开启标签模式时，裸 /v1/* 会按 overlay 后的模型归属把请求分发到真正的上游 provider。
DEFAULT_PROVIDER=openai

# 是否启用默认分组模型标签模式。
# true 后放弃 overlay 覆盖模式；默认分组模型改为按 [providerId]model 路由。
ENABLE_DEFAULT_PROVIDER_MODEL_TAGS=false

# 是否让标签模式下的所有默认分组模型都强制带标签。
# false 时只给冲突模型打标签；true 时所有模型都打标签。
ENABLE_ALL_DEFAULT_PROVIDER_MODEL_TAGS=false

# 是否启用旧版 /v1/* 兼容路由。
# 开启后，/v1/chat/completions、/v1/responses、/v1/messages、/v1/models 会走 DEFAULT_PROVIDER 的 overlay 或标签模式。
ENABLE_LEGACY_V1_ROUTES=true

# 是否启用结构化日志。
LOG_ENABLE=false

# 结构化日志文件路径。
LOG_FILE_PATH=.proxy.requests.jsonl

# 单个请求 body 最大 MB 数（Unicode 字符），超过则截断并追加 ...[TRUNCATED]。
# 设为 0 表示不截断。
LOG_MAX_BODY_SIZE_MB=5

# 结构化日志最大保留请求数（按修改时间自动清理）。
LOG_MAX_REQUESTS=200

# 调试归档目录；留空表示关闭。
OPENAI_COMPAT_DEBUG_ARCHIVE_DIR=
