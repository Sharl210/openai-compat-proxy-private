# 服务名
APP_NAME=openai-compat-proxy

# 代理监听地址
LISTEN_ADDR=:18082

# 旧版单上游回退配置。
# 新版多 provider 部署优先使用 PROVIDERS_DIR + 每个 provider 独立 *.env 文件。
UPSTREAM_BASE_URL=https://api-vip.codex-for.me/v1
UPSTREAM_API_KEY=

# provider 配置目录。
# 目录里每个 provider 一份真实配置文件，例如 ./providers/openai.env
PROVIDERS_DIR=./providers

# 旧版 /v1/* 路由使用的默认 provider。
# 当 ENABLE_LEGACY_V1_ROUTES=true 时，这里必须指向且只能指向一个已配置 provider。
DEFAULT_PROVIDER=

# 是否保留旧版裸 /v1/chat/completions、/v1/responses、/v1/models。
# 开启后这些路由都会作为 DEFAULT_PROVIDER 的兼容别名。
ENABLE_LEGACY_V1_ROUTES=false

# 代理自身的访问密钥，可选
PROXY_API_KEY=

# 日志总开关，默认 false
LOG_ENABLE=false

# 结构化请求日志文件路径
LOG_FILE_PATH=.proxy.requests.jsonl

# 是否在日志中包含原始请求/响应 body
LOG_INCLUDE_BODIES=false

# 单个日志文件滚动前的最大大小（MB）
LOG_MAX_SIZE_MB=100

# 最多保留多少个滚动后的日志文件
LOG_MAX_BACKUPS=10
