# ==============================
# 全局运行时配置模板
# ==============================
#
# 这个文件就是全局运行时配置源。
# 进程会监听这个文件，但只有“可热加载字段”变更且整份候选配置校验通过后才会生效。
#
# 当前可热加载：
# - PROXY_API_KEY
# - PROVIDERS_DIR
# - DEFAULT_PROVIDER
# - ENABLE_LEGACY_V1_ROUTES
# - DOWNSTREAM_NON_STREAM_STRATEGY
# - CONNECT_TIMEOUT
# - FIRST_BYTE_TIMEOUT
# - IDLE_TIMEOUT
# - TOTAL_TIMEOUT
# - UPSTREAM_USER_AGENT
# - UPSTREAM_MASQUERADE_TARGET
#
# 当前不能热加载（修改后会被运行时忽略，仍以进程启动时加载值为准）：
# - LISTEN_ADDR
# - CACHE_INFO_TIMEZONE
# - LOG_ENABLE
# - LOG_FILE_PATH
# - LOG_INCLUDE_BODIES
# - LOG_MAX_SIZE_MB
# - LOG_MAX_BACKUPS

# 代理监听地址。
# 不能热加载；修改后需要重启进程。
# 如果显式写了主机，例如 127.0.0.2:21021，部署脚本和健康检查会按这个主机探测，不再固定使用 127.0.0.1。
LISTEN_ADDR=:21021

# Cache_Info 统计展示使用的时区。
# provider 的 JSON 统计快照会落到 <PROVIDERS_DIR>/Cache_Info/SYSTEM_JSON_FILES/。
# provider 的 TXT 统计仍会落到 <PROVIDERS_DIR>/Cache_Info/。
# 默认值是 Asia/Shanghai。
# 只支持 IANA 时区名称，例如 Asia/Shanghai、UTC。
# 不能热加载；修改后需要重启进程。
CACHE_INFO_TIMEZONE=Asia/Shanghai

# 根级代理层鉴权 key。
# provider 没有设置 PROXY_API_KEY_OVERRIDE 时会继承它。
# 默认 provider 的裸 /v1/* 路由也使用这把 key。
# 留空表示未继承它的 provider 不需要代理鉴权。
# 可热加载。
PROXY_API_KEY=

# provider 配置目录。
# 运行时会监听这个目录下真实的 *.env，并忽略 *.env.example。
# provider 模板默认还会引用同目录下的 prompt.md 作为 provider 级系统提示词文件；
# 修改对应 prompt 文件内容也会热加载生效。
# provider 文件里的 UPSTREAM_ENDPOINT_TYPE 如果写成非法值，
# 新快照不会生效，运行时会继续保留当前已生效配置。
# provider 文件里的 UPSTREAM_RETRY_COUNT / UPSTREAM_RETRY_DELAY 如果写成非法值，
# 新快照不会生效，运行时会继续保留当前已生效配置。
# 这个字段本身可热加载；但 Cache_Info 目录仍使用进程启动时初始化的 PROVIDERS_DIR。
# 如果你希望 Cache_Info 统计文件也切到新目录，需要重启进程。
PROVIDERS_DIR=./providers

# 裸 /v1/* 路由使用的默认 provider。
# 当 ENABLE_LEGACY_V1_ROUTES=true 时必须存在且可用。
# 可热加载。
DEFAULT_PROVIDER=openai

# 是否启用裸 /v1/chat/completions、/v1/responses、/v1/messages、/v1/models。
# 设为 false 后，只允许 /{providerId}/v1/* 显式路由。
# 必须写成合法布尔值；非法值会让根配置校验失败。
# 可热加载。
ENABLE_LEGACY_V1_ROUTES=true

# 下游请求本身是非流式时，代理请求上游 /responses 的模式。
# proxy_buffer：继续保持现状，向上游请求 SSE，再由代理层聚合成非流式响应。
# upstream_non_stream：下游非流时直接向上游请求非流式 JSON 响应。
# 默认是 proxy_buffer；provider 可以再用 DOWNSTREAM_NON_STREAM_STRATEGY_OVERRIDE 覆盖它。
# 可热加载。
DOWNSTREAM_NON_STREAM_STRATEGY=proxy_buffer

# 连接上游时的 TCP 建连超时。
# 可热加载。
CONNECT_TIMEOUT=10s

# 等待上游响应头 / 首字节的最长时间。
# 根级默认值是 20m；provider 没有单独设置时会继承它。
# 可热加载。
FIRST_BYTE_TIMEOUT=20m

# 读取活跃上游响应体 / 流时允许的最长静默间隔。
# 可热加载。
IDLE_TIMEOUT=3m

# 单次请求的总超时时间。
# 可热加载。
TOTAL_TIMEOUT=1h

# 上游请求时使用的 User-Agent 头。
# 用于伪装成特定客户端以绕过某些代理服务的客户端限制。
# 例如可设置为 opencode 的客户端标识来绕过 sub2api 的限制。
# 留空则不设置 User-Agent 头。
# 可热加载。
UPSTREAM_USER_AGENT=

# 伪装目标客户端标识。
# 用于绕过 sub2api 等代理服务的客户端限制。
# 可选值：opencode（伪装 opencode）、claude（伪装 Claude Code）、codex（伪装 OpenAI Codex CLI）、none（不做伪装）。
# 留空或 none 表示不启用伪装。
# openai: 发送 opencode User-Agent + originator: opencode
# claude: 发送 claude-cli User-Agent + anthropic-beta + X-App 等完整头部
# codex: 发送 codex_cli_rs User-Agent
# 可热加载。
UPSTREAM_MASQUERADE_TARGET=

# 是否向上游 Anthropic 请求体中注入 metadata.user_id。
# 用于 Claude Code 伪装档绕过 sub2api 的 metadata.user_id 格式校验。
# 必须写成合法布尔值。
# 可热加载。
UPSTREAM_INJECT_METADATA_USER_ID=false

# 是否向上游 Anthropic 请求体中注入 Claude Code 真实 system prompt。
# 用于 Claude Code 伪装档绕过 sub2api 的 system prompt Dice 系数相似度校验。
# 必须写成合法布尔值。
# 可热加载。
UPSTREAM_INJECT_CLAUDE_SYSTEM_PROMPT=false

# 是否启用结构化请求日志。
# 启动时必须写成合法布尔值；非法值会让根配置校验失败。
# 不能热加载；修改后需要重启进程。
LOG_ENABLE=false

# 结构化日志文件路径。
# 不能热加载；修改后需要重启进程。
LOG_FILE_PATH=.proxy.requests.jsonl

# 是否把原始请求/响应 body 写入结构化日志。
# 设为 false 表示不记录 body。
# 启动时必须写成合法布尔值；非法值会让根配置校验失败。
# 不能热加载；修改后需要重启进程。
LOG_INCLUDE_BODIES=false

# 单个结构化日志文件的最大大小（MB）。
# 不能热加载；修改后需要重启进程。
LOG_MAX_SIZE_MB=100

# 最多保留多少个轮转后的结构化日志文件。
# 不能热加载；修改后需要重启进程。
LOG_MAX_BACKUPS=10
