# Service name
APP_NAME=openai-compat-proxy

# Proxy listen address
LISTEN_ADDR=:18082

# Upstream OpenAI-compatible endpoint and credentials
UPSTREAM_BASE_URL=https://api-vip.codex-for.me/v1
UPSTREAM_API_KEY=

# Optional key required by this proxy itself
PROXY_API_KEY=

# Logging master switch (default false)
LOG_ENABLE=false

# Structured request log file path
LOG_FILE_PATH=.proxy.requests.jsonl

# Whether to include raw request/response bodies in logs
LOG_INCLUDE_BODIES=false

# Max size per log file before rotation (MB)
LOG_MAX_SIZE_MB=100

# How many rotated log files to keep
LOG_MAX_BACKUPS=10
