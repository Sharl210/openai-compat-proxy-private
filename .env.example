# 应用名（可选）
APP_NAME=openai-compat-proxy

# 监听地址
LISTEN_ADDR=:21021

# 默认上游基础地址。
# 单上游模式直接使用这里；多 provider 模式下，这组值仍建议保留，便于部署脚本校验与兜底。
UPSTREAM_BASE_URL=https://api.example.com/v1

# 默认上游 API Key。
UPSTREAM_API_KEY=

# 代理自身鉴权 key（可选）。
# 设置后，调用方需要带 Authorization: Bearer <proxy-key> / X-API-Key / Api-Key。
PROXY_API_KEY=

# provider 配置目录。
# 程序只会读取这个目录下的 *.env，不会读取 *.env.example。
PROVIDERS_DIR=./providers

# 默认 provider id。
# 开启旧版 /v1/* 兼容路由时建议显式设置。
DEFAULT_PROVIDER=openai

# 是否启用旧版 /v1/* 兼容路由。
# 开启后，/v1/chat/completions、/v1/responses、/v1/messages、/v1/models 会走默认 provider。
ENABLE_LEGACY_V1_ROUTES=true

# 是否启用结构化日志。
LOG_ENABLE=false

# 结构化日志文件路径。
LOG_FILE_PATH=.proxy.requests.jsonl

# 是否记录原始请求/响应 body。
# 仅 true / 1 会开启，默认建议关闭。
LOG_INCLUDE_BODIES=false

# 单个日志文件最大大小（MB）。
LOG_MAX_SIZE_MB=100

# 最多保留多少个轮转归档文件。
LOG_MAX_BACKUPS=10
