# ==============================
# 全局运行时配置模板
# ==============================
#
# 这个文件就是全局运行时配置源。
# 进程会监听这个文件，但只有"可热加载字段"变更且整份候选配置校验通过后才会生效。
#
# 当前可热加载：
# - PROXY_API_KEY
# - PROVIDERS_DIR
# - DEFAULT_PROVIDER
# - V1_MODEL_MAP
# - ENABLE_LEGACY_V1_ROUTES
# - DOWNSTREAM_NON_STREAM_STRATEGY
# - CONNECT_TIMEOUT
# - FIRST_BYTE_TIMEOUT
# - IDLE_TIMEOUT
# - TOTAL_TIMEOUT
# - UPSTREAM_USER_AGENT
# - UPSTREAM_MASQUERADE_CLIENT_VERSION
# - UPSTREAM_MASQUERADE_TARGET
# - UPSTREAM_INJECT_METADATA_USER_ID
# - UPSTREAM_INJECT_CLAUDE_SYSTEM_PROMPT
# - UPSTREAM_CLAUDE_CODE_METADATA_DEVICE_ID
# - UPSTREAM_CLAUDE_CODE_METADATA_ACCOUNT_UUID
# - UPSTREAM_MAX_OUTPUT_TOKENS
# - FORCE_UPSTREAM_MAX_OUTPUT_TOKENS
# - MODEL_LIMIT_CONTEXT_TOKENS
#
# 当前不能热加载（修改后会被运行时忽略，仍以进程启动时加载值为准）：
# - LISTEN_ADDR
# - CACHE_INFO_TIMEZONE
# - LOG_ENABLE
# - LOG_FILE_PATH
# - LOG_MAX_BODY_SIZE_MB
# - LOG_MAX_REQUESTS
# - OPENAI_COMPAT_DEBUG_ARCHIVE_DIR
# - OPENAI_COMPAT_DEBUG_ARCHIVE_MAX_REQUESTS

# ========== 基础配置 ==========
# 代理监听地址。
# 不能热加载；修改后需要重启进程。
# 如果显式写了主机，例如 127.0.0.2:21021，部署脚本和健康检查会按这个主机探测，不再固定使用 127.0.0.1。
LISTEN_ADDR=:21021

# Cache_Info 统计展示以及版本时间响应头（如 X-Root-Env-Version / X-Provider-Version）使用的时区。
# provider 的 JSON 统计快照会落到 <PROVIDERS_DIR>/Cache_Info/SYSTEM_JSON_FILES/。
# provider 的 TXT 统计会落到 <PROVIDERS_DIR>/Cache_Info/，
# 包括单 provider 文件、全提供商总计、已启用提供商总计，以及 v1默认分组统计。
# 默认值是 Asia/Shanghai。
# 只支持 IANA 时区名称，例如 Asia/Shanghai、UTC。
# 不能热加载；修改后需要重启进程。
CACHE_INFO_TIMEZONE=Asia/Shanghai

# ========== 代理鉴权 ==========
# 根级代理层鉴权 key。
# provider 没有设置 PROXY_API_KEY_OVERRIDE 时会继承它。
# 默认 provider 的裸 /v1/* 路由也使用这把 key。
# provider 作用域请求状态查询 /{providerId}/v1/requests/{requestId} 不会使用这把 key。
# 留空表示未继承它的 provider 不需要代理鉴权。
# 可热加载。
PROXY_API_KEY=

# ========== Provider 路由 ==========
# provider 配置目录。
# 运行时会监听这个目录下真实的 *.env，并忽略 *.env.example。
# provider 模板默认还会引用同目录下的 prompt.md 作为 provider 级系统提示词文件；
# 修改对应 prompt 文件内容也会热加载生效。
# provider 文件里的 UPSTREAM_ENDPOINT_TYPE 如果写成非法值，
# 新快照不会生效，运行时会继续保留当前已生效配置。
# 根 .env 或 provider 文件里的 UPSTREAM_MAX_OUTPUT_TOKENS / FORCE_UPSTREAM_MAX_OUTPUT_TOKENS / MODEL_LIMIT_CONTEXT_TOKENS 如果写成非法值（包括 scoped 规则里的 value 非法），
# 新快照不会生效，运行时会继续保留当前已生效配置。
# provider 文件里的 UPSTREAM_RETRY_COUNT / UPSTREAM_RETRY_DELAY 如果写成非法值（UPSTREAM_RETRY_COUNT=0 表示关闭代理层重试，负数非法），
# 新快照不会生效，运行时会继续保留当前已生效配置。
# 这个字段本身可热加载；但 Cache_Info 目录仍使用进程启动时初始化的 PROVIDERS_DIR。
# 如果你希望 Cache_Info 统计文件也切到新目录，需要重启进程。
PROVIDERS_DIR=./providers

# 裸 /v1/* 路由使用的默认 provider overlay 列表。
# 支持单个 provider id，也支持用逗号分隔多个 provider id，例如 openai,azure。
# 越靠后的 provider 优先级越高；同名模型会覆盖前面的 provider。
# 当未开启下方的标签模式时，裸 /v1/models 会按这组 overlay 后的可见模型返回。
# 当未开启下方的标签模式时，裸 /v1/responses、/v1/chat/completions、/v1/messages 会按模型归属选择真正的上游 provider。
# 当 ENABLE_LEGACY_V1_ROUTES=true 时，这里列出的 provider 都必须存在且启用。
# 可热加载。
DEFAULT_PROVIDER=openai

# 裸 /v1/* 路由专用模型预映射，只在默认 provider/group 路由选择前生效。
# 它只决定默认分组路由前的临时模型名，不替代 provider 级 MODEL_MAP。
# 格式与 provider 级 MODEL_MAP 相同：src:target,src2:target2。
# src 默认按字面量精确匹配；只有以 #re: 开头时才按 Go regexp 全字符串匹配。
# #re: 模式支持捕获替换，仅支持 $0-$9；$0 是完整匹配，$1-$9 是第 1 到第 9 个捕获组。
# $10 及以上会保留字面值，避免歧义；target 里如果要输出字面 $，写成 \$。
# 例如 V1_MODEL_MAP=gpt-5.5:gpt-5.6,#re:mini(.*)o:real-$0-$1 会把 gpt-5.5 映射为 gpt-5.6，把 mini2o 映射为 real-mini2o-2。
# #re: 内的正则转义完全按 Go regexp 处理，例如 \* 匹配字面星号，\. 匹配字面点。
# 兜底正则匹配写成 #re:.*；单独 * 不是合法 regexp。
# 处理顺序：V1_MODEL_MAP -> DEFAULT_PROVIDER/default group 路由 -> provider MODEL_ID_TEMPLATE 解包 -> provider MODEL_MAP + reasoning suffix。
# V1_MODEL_MAP 不读取请求体里的 reasoning 参数，也不会在预映射阶段主动剥离或解析 reasoning suffix。
# target 中的 suffix 只有进入后续 provider MODEL_MAP + reasoning suffix 阶段后，才可能按 provider 规则成为最终 effort。
# 例如 V1_MODEL_MAP=client-gpt:gpt-5.5 时，客户端请求 client-gpt 会变成 gpt-5.5；客户端请求 client-gpt-high 不会直接命中 client-gpt 这条左侧规则。
# 例如 V1_MODEL_MAP=client-gpt-high:gpt-5.5 时，只有客户端请求 client-gpt-high 才直接命中这条规则。
# 例如 V1_MODEL_MAP=client-gpt:gpt-5.5-low 时，客户端请求 client-gpt 会先变成 gpt-5.5-low；之后是否把 low 当作 effort，取决于后续 provider 级 MODEL_MAP + reasoning suffix 处理。
# 它只影响 /v1/* 和无 /v1 裸别名，不影响 /{providerId}/v1/* 显式 provider 路由。
# 如果 target 不在默认分组可见模型列表中，请求会按现有 invalid_model 路径失败。
# 可热加载。
V1_MODEL_MAP=

# 是否启用默认分组模型标签模式。
# false：继续使用 DEFAULT_PROVIDER 的 overlay 规则；同名模型由后面的 provider 覆盖前面的 provider。
# true：放弃 overlay 覆盖模式，改为按标签区分默认分组模型来源。
#   - ENABLE_ALL_DEFAULT_PROVIDER_MODEL_TAGS=false 时：只有冲突/重叠模型会显示成 [providerId]model；唯一模型仍保留原名。
#   - ENABLE_ALL_DEFAULT_PROVIDER_MODEL_TAGS=true 时：所有默认分组模型都显示成 [providerId]model。
# 开启后，裸 /v1/* 里带标签的模型会强制路由到对应 provider；未带标签的冲突模型不会再回退到 overlay。
# 可热加载。
ENABLE_DEFAULT_PROVIDER_MODEL_TAGS=false

# 是否让默认分组模型标签模式进入“全量打标签”。
# 只有在 ENABLE_DEFAULT_PROVIDER_MODEL_TAGS=true 时才生效。
# false：只给冲突/重叠模型打标签（默认行为）。
# true：所有默认分组模型都打标签。
# 可热加载。
ENABLE_ALL_DEFAULT_PROVIDER_MODEL_TAGS=false

# 是否启用模型名 -noprompt 后缀跳过 provider prompt 注入。
# true：客户端请求 gpt-5.5-noprompt / gpt-5.5-low-noprompt 时，代理会剥掉 -noprompt，
#       再按 gpt-5.5 / gpt-5.5-low 继续处理模型和 reasoning suffix，并跳过 provider 配置里的 SYSTEM_PROMPT_FILES 注入。
#       客户端自己传的 instructions/system 不会被删除；-noprompt 不会带到上游。
# false：-noprompt 按普通模型名处理，不做特殊剥离；如果客户端带了 -noprompt，透明度响应头会显示 X-Client-To-Proxy-NoPrompt=false。
# 这类 -noprompt 变体不会额外出现在 /models 列表里。
# provider 级 ENABLE_NOPROMPT_MODEL_SUFFIX 留空时继承这里；写 true / false 时覆盖这里。
# 可热加载。
ENABLE_NOPROMPT_MODEL_SUFFIX=true

# 根级上游最大输出 token 数，作为所有 provider 的默认值。
# provider 文件里的 UPSTREAM_MAX_OUTPUT_TOKENS 留空或不写时继承这里；显式写正整数、scoped 规则或 -1 时覆盖这里。
# 支持三种写法：
#   1. 单个默认值，例如 64000
#   2. 默认值 + 精确模型覆写，例如 64000,claude-sonnet-4-5:128000
#   3. 默认值 + 精确模型 + 正则覆写，例如 64000,claude-sonnet-4-5:128000,#re:.*claude-.*:100000
# scoped 规则按最终真正发给上游的模型匹配，精确模型优先于正则匹配。
# 字面量 base 模型名默认代表整一个推理家族，不仅覆盖显式 suffix 成员，也覆盖“模型名本身不带 suffix、但请求体显式带推理参数”的等效成员。
# 例如 provider 里 MODEL_MAP=gpt-5.5:claude-sonnet-4-5，客户端请求 gpt-5.5 时，应写 UPSTREAM_MAX_OUTPUT_TOKENS=claude-sonnet-4-5:128000。
# 如果客户端请求 gpt-5.5-high，则 claude-sonnet-4-5:128000 会作为家族 base 规则命中；如果同时写了 claude-sonnet-4-5-high:160000，则 high 成员规则优先。
# `-noprompt` 只是代理层跳过 provider prompt 注入的标记，不算独立模型；带这个标记的请求会继续复用去掉标记后的同一模型规则。
# 这个字段控制的是发给上游的输出上限请求参数 max_tokens / max_output_tokens，不是上下文窗口大小。
# 填入 -1 表示代理主动不携带最大输出 token 字段。
# 可热加载。
UPSTREAM_MAX_OUTPUT_TOKENS=64000

# 根级 Anthropic 上游 cache_control 兼容模式。
# provider 文件里的 UPSTREAM_ANTHROPIC_CACHE_CONTROL 留空或不写时继承这里；显式写 5min、1h、false、nochange 时覆盖这里。
# 5min：把 Anthropic 内容块里的 cache_control 统一写成 {"type":"ephemeral"}。
# 1h：把 Anthropic 内容块里的 cache_control 统一写成 {"type":"ephemeral","ttl":"1h"}。
# false：删除 Anthropic 内容块里的 cache_control。
# nochange：保留客户端原样传来的 cache_control，不做改写。
# 可热加载。
UPSTREAM_ANTHROPIC_CACHE_CONTROL=5min

# 是否强制使用根级上游最大输出 token 数。
# provider 文件里的 FORCE_UPSTREAM_MAX_OUTPUT_TOKENS 留空或不写时继承这里；显式 true / false 时覆盖这里。
# false：只在客户端请求没有携带 max_tokens / max_output_tokens 时补 UPSTREAM_MAX_OUTPUT_TOKENS。
# true：只要最终继承或覆盖后的 UPSTREAM_MAX_OUTPUT_TOKENS 已设置，就忽略客户端请求里的输出上限。
# 可热加载。
FORCE_UPSTREAM_MAX_OUTPUT_TOKENS=false

# Anthropic manual thinking 的默认最大思考预算，单位是 token。
# 这个值是让用户直接填写的“最高 thinking.budget_tokens 预算”，不是倍率，也不是模型上下文窗口。
# provider 文件里的 ANTHROPIC_MAX_THINKING_BUDGET 留空或不写时继承这里；显式写大于等于 1024 的整数时覆盖这里。
# 只有同时满足以下条件时才会用到这个值：上游是 anthropic 协议、启用了 MAP_REASONING_SUFFIX_TO_ANTHROPIC_THINKING、最终 effort 需要转成 manual thinking.budget_tokens。
# Claude adaptive thinking 模型会优先走 output_config.effort，不按这个数字切 budget；OpenAI 风格上游也不会读取这个字段。
# Anthropic 官方要求 manual budget_tokens 大于等于 1024，且普通 manual thinking 下必须小于 max_tokens；官方没有给出独立全局最大值。
# 代理会把这个最大预算动态切成 6 个非 none 档位：minimal≈1/16、low≈1/8、medium≈1/4、high≈1/2、xhigh=max、max=max。
# 例如这里填 32000 时，minimal/low/medium/high/xhigh/max 分别约为 2000/4000/8000/16000/32000/32000。
# 例如这里填 40000 时，high 会生成约 20000；如果同一请求 max_tokens=12000，因为 Anthropic 要求 budget_tokens < max_tokens，最终会发送 11999。
# 可热加载。
ANTHROPIC_MAX_THINKING_BUDGET=32000

# 根级推理摘要详细度默认值。
# provider 文件里的 REASONING_SUMMARY_DETAIL 留空或不写时继承这里；显式写 none / auto / detailed 时覆盖根配置。
# 可选值：
#   - none：尽量不请求 reasoning summary
#   - auto：让上游按默认/最佳可用档位返回 summary
#   - detailed：尽量请求最详细的 summary；对于只有 summarized/auto 两档的上游，会自动降级成其可用的“显示摘要”档位
# 默认值是 detailed。
# 可热加载。
REASONING_SUMMARY_DETAIL=detailed

# 代理层模拟的模型上下文窗口限制。
# provider 文件里的 MODEL_LIMIT_CONTEXT_TOKENS 留空或不写时继承这里；显式写正整数、scoped 规则或 -1 时覆盖这里。
# -1 表示代理层不主动限制上下文；真实上游自己的上下文限制仍然照常生效。
# 它不是“自动探测真实上游最大上下文值”，而是“不由代理层限制”。
# 正整数表示代理按请求内容估算输入 token，超过该值时在代理层直接模拟 context_length_exceeded / prompt is too long。
# 这个模拟用于让 OpenCode 等客户端触发自动压缩；它不会扩大真实模型上下文，也不会阻止上游更早返回真实超限。
# 支持 scoped 写法，例如 MODEL_LIMIT_CONTEXT_TOKENS=-1,claude-sonnet-4-5:400000,#re:.*claude-.*:256000。
# scoped 规则按最终真正发给上游的模型匹配，精确模型优先于正则匹配。
# 字面量 base 模型名默认代表整一个推理家族，不仅覆盖显式 suffix 成员，也覆盖“模型名本身不带 suffix、但请求体显式带推理参数”的等效成员。
# 例如 provider 里 MODEL_MAP=gpt-5.5:claude-sonnet-4-5，客户端请求 gpt-5.5 时，应写 MODEL_LIMIT_CONTEXT_TOKENS=claude-sonnet-4-5:400000。
# 如果客户端请求 gpt-5.5-high，则 claude-sonnet-4-5:400000 会作为家族 base 规则命中；如果同时写了 claude-sonnet-4-5-high:200000，则 high 成员规则优先。
# `-noprompt` 只是代理层跳过 provider prompt 注入的标记，不算独立模型；带这个标记的请求会继续复用去掉标记后的同一模型规则。
# 这个字段限制的是代理估算的输入上下文窗口，用于提前模拟 prompt is too long；它和 UPSTREAM_MAX_OUTPUT_TOKENS 控制的输出上限参数互不冲突。
# 命中限制时，代理会在错误 message 里附带 `estimated input tokens <current> exceed maximum <limit>`，方便 OpenCode / OMO 识别为 token-limit 触发源。
# 可热加载。
MODEL_LIMIT_CONTEXT_TOKENS=-1

# 是否启用裸 /v1/chat/completions、/v1/responses、/v1/messages、/v1/models。
# 设为 false 后，只允许 /{providerId}/v1/* 显式路由。
# 必须写成合法布尔值；非法值会让根配置校验失败。
# 可热加载。
ENABLE_LEGACY_V1_ROUTES=true

# ========== 超时控制 ==========
# 下游请求本身是非流式时，代理向上游发起请求的模式。
# proxy_buffer：继续保持现状，向上游请求 SSE，再由代理层聚合成非流式响应。
# upstream_non_stream：下游非流时直接向上游请求非流式 JSON 响应。
# 默认是 proxy_buffer；provider 可以再用 DOWNSTREAM_NON_STREAM_STRATEGY_OVERRIDE 覆盖它。
# 可热加载。
DOWNSTREAM_NON_STREAM_STRATEGY=proxy_buffer

# 连接上游时的 TCP 建连超时。
# 可热加载。
CONNECT_TIMEOUT=30s

# 等待上游响应头 / 首字节的最长时间。
# 根级默认值是 30m；provider 没有单独设置时会继承它。
# 可热加载。
FIRST_BYTE_TIMEOUT=30m

# 流式请求在还没有向下游写出任何 SSE 之前，等待上游打开响应头的最长时间。
# 它专门保护 /v1/responses、/v1/chat/completions、/v1/messages 的 stream=true 入口，避免上游首包前慢失败时让客户端长时间无任何响应。
# 例如 FIRST_BYTE_TIMEOUT=30m 可以继续保留给普通上游响应头等待，但 STREAM_OPEN_TIMEOUT=360s 会给慢上游最多 6 分钟打开流。
# provider 可用 UPSTREAM_STREAM_OPEN_TIMEOUT 单独覆盖；可热加载。
STREAM_OPEN_TIMEOUT=360s

# 读取活跃上游响应体 / 流时允许的最长静默间隔。
# 可热加载。
IDLE_TIMEOUT=3m

# 单次请求的总超时时间。
# 可热加载。
TOTAL_TIMEOUT=1h

# ========== 结构化日志 ==========
# 是否启用结构化请求日志。
# 默认 true。
# 不能热加载；修改后需要重启进程。
LOG_ENABLE=true

# 结构化日志落盘目录。
# 默认值是 logs。
# 不能热加载；修改后需要重启进程。
LOG_FILE_PATH=logs

# 单个请求 body 最大 MB 数（Unicode 字符），超过则截断并追加 "...[TRUNCATED]"。
# 设为 0 表示不截断。默认 5。
# 不能热加载；修改后需要重启进程。
LOG_MAX_BODY_SIZE_MB=5

# 结构化日志最大保留请求数（按修改时间自动清理）。
# 默认 200。
# 不能热加载；修改后需要重启进程。
LOG_MAX_REQUESTS=200

# 调试归档目录。
# 这是调试归档子开关；只有 LOG_ENABLE=true 且此字段非空时，才会按 request_id 在该目录下写入 request.ndjson、raw.ndjson、canonical.ndjson、final.ndjson。
# archive 目录的最大保留 request_id 数量由 OPENAI_COMPAT_DEBUG_ARCHIVE_MAX_REQUESTS 独立控制，与 LOG_MAX_REQUESTS 完全解耦。
# 超过该数量后按目录修改时间自动清理旧归档。
# 这个能力用于开发调试与问题复盘，不面向人类摘要阅读。
# 不能热加载；修改后需要重启进程。
OPENAI_COMPAT_DEBUG_ARCHIVE_DIR=OPENAI_COMPAT_DEBUG_ARCHIVE_DIR

# 调试归档目录的最大保留 request_id 数量。
# 只有当 LOG_ENABLE=true 且 OPENAI_COMPAT_DEBUG_ARCHIVE_DIR 已设置（非空）时此字段才生效。
# 默认 200；必须是大于等于 1 的整数，非正数或非法值会让根配置校验失败。
# 这个值与 LOG_MAX_REQUESTS 完全独立，互不影响。
# 不能热加载；修改后需要重启进程。
OPENAI_COMPAT_DEBUG_ARCHIVE_MAX_REQUESTS=200

# ========== 伪装相关 ==========
# 上游请求时使用的自定义 User-Agent 头。
# 这是一个完全独立的字段，与伪装目标 UPSTREAM_MASQUERADE_TARGET 不冲突；
# 优先级高于伪装目标对 User-Agent 的修改（如果设置了，就直接覆盖伪装生成的 User-Agent）。
# 其他伪装专属头（originator / X-App 等）不受此字段影响，仍由 MASQUERADE_TARGET 决定。
# 留空则不设置。
# 可热加载。
UPSTREAM_USER_AGENT=

# 上游伪装客户端版本。
# 留空表示使用代码默认值；provider 级留空会继承这里。
# 参考值：claude=2.1.183，codex=0.141.0，opencode=1.17.8。
# 可热加载。
UPSTREAM_MASQUERADE_CLIENT_VERSION=

# 伪装目标客户端标识，用于绕过 sub2api 等代理服务的客户端限制。
#
# 语义说明：
#   - 留空：继承上层（provider 级别继承根 .env）配置。
#   - none：显式禁用伪装（不等效于"继承"，是主动关掉）。
#   - opencode / claude / codex：启用对应伪装档。
#
# 优先级说明：
#   UPSTREAM_USER_AGENT（自定义 UA）始终覆盖伪装目标对 User-Agent 的修改，
#   但不改变其他伪装档专属头（originator / X-App 等）。
#
# 可选值及效果：
#   opencode：发送 User-Agent: opencode/1.17.8 ai-sdk/provider-utils/4.0.27 runtime/bun/1.3.14
#            + originator: opencode
#            适用于绕过 sub2api 对 originator 前缀的校验。
#   claude：  发送 User-Agent: claude-cli/2.1.183 (external, cli) + X-App: cli
#            + anthropic-beta: claude-code-20250219,oauth-2025-04-20,interleaved-thinking-2025-05-14,
#              prompt-caching-scope-2026-01-05,effort-2025-11-24,context-management-2025-06-27,
#              extended-cache-ttl-2025-04-11
#            + X-Stainless-* 等完整 Claude Code 头。
#            适用于 /messages 路径；默认会注入 metadata.user_id 和新版无 cch 的 system billing marker。
#   codex：   发送 User-Agent: codex_cli_rs/0.141.0 (Linux 6.1; x86_64) iTerm.app
#            + originator: codex_cli_rs + x-openai-internal-codex-residency: us。
#            + OpenAI 风格上游会补 x-codex-window-id，提供 x-codex-* 引擎指纹痕迹。
#            + 当请求带 reasoning 时自动补 include=reasoning.encrypted_content。
#            适用于绕过 sub2api 对 codex_cli_rs/ 严格前缀和引擎指纹的校验，并更贴近真实 Codex CLI 请求形态。
#   none：    显式禁用伪装，不注入任何伪装 header。
# 可热加载。
UPSTREAM_MASQUERADE_TARGET=

# 是否向上游 Anthropic 请求体中注入 metadata.user_id。
# 仅在本层或继承上层的有效伪装目标为 claude 时才生效。
# 用于 Claude Code 伪装档绕过 sub2api 的 metadata.user_id 格式校验。
# 默认 true；只有明确不需要完整 Claude Code 伪装时才改成 false。
# 必须写成合法布尔值。
# 根级只有 true/false 两态；provider 级如果要继承这里，请在 provider 模板里留空对应字段。
# 可热加载。
UPSTREAM_INJECT_METADATA_USER_ID=true

# Claude Code metadata.user_id 里的稳定设备 ID。
# 仅在有效伪装目标为 claude 且 UPSTREAM_INJECT_METADATA_USER_ID=true 时进入上游请求体。
# 留空表示代理按 provider ID 生成稳定默认值；同一 provider 固定，不同 provider 不同。
# 必须是 64 位十六进制字符串。
# session_id 不在配置里填写，代理会为每次请求动态生成合法 UUID。
# 可热加载。
UPSTREAM_CLAUDE_CODE_METADATA_DEVICE_ID=

# Claude Code metadata.user_id 里的稳定账户 UUID。
# 仅在有效伪装目标为 claude 且 UPSTREAM_INJECT_METADATA_USER_ID=true 时进入上游请求体。
# 留空表示代理按 provider ID 生成稳定默认值；同一 provider 固定，不同 provider 不同。
# 必须是 UUID 格式。
# session_id 不在配置里填写，代理会为每次请求动态生成合法 UUID。
# 可热加载。
UPSTREAM_CLAUDE_CODE_METADATA_ACCOUNT_UUID=

# 是否向上游 Anthropic 请求体中注入 Claude Code 真实 system prompt。
# 仅在本层或继承上层的有效伪装目标为 claude 时才生效。
# 用于 Claude Code 伪装档绕过 sub2api 的 system prompt / billing marker 校验；billing marker 使用新版无 cch 格式。
# 默认 true；只有明确不需要完整 Claude Code 伪装时才改成 false。
# 必须写成合法布尔值。
# 根级只有 true/false 两态；provider 级如果要继承这里，请在 provider 模板里留空对应字段。
# 可热加载。
UPSTREAM_INJECT_CLAUDE_SYSTEM_PROMPT=true
