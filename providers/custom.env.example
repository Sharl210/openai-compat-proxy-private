# 通用 provider 示例
# 复制为 providers/custom.env 后填写真实值。

# 必填。provider 唯一 id，会出现在 provider 路由中。
PROVIDER_ID=custom

# 必填。是否启用这个 provider。
PROVIDER_ENABLED=true

# 可选。最多只能有一个 provider 被标记为默认 provider。
PROVIDER_IS_DEFAULT=false

# 必填。上游 Responses 兼容接口基础地址。
UPSTREAM_BASE_URL=https://example-custom-provider.com/v1

# 必填（除非调用方总是自己传 X-Upstream-Authorization）。
UPSTREAM_API_KEY=

# 这个 provider 对外暴露哪些协议能力。
SUPPORTS_CHAT=true
SUPPORTS_RESPONSES=true
SUPPORTS_MODELS=true
SUPPORTS_ANTHROPIC_MESSAGES=false

# 可选。provider 级模型映射。
# MODEL_MAP_JSON={"gpt-5":"vendor-model-name"}

# 可选。provider 级 reasoning 后缀开关。
# ENABLE_REASONING_EFFORT_SUFFIX=false

# 可选。是否在 /models 中直接展示扩展后的后缀模型名。
# 只有当 ENABLE_REASONING_EFFORT_SUFFIX=true 时，这个开关才有意义。
# EXPOSE_REASONING_SUFFIX_MODELS=false
