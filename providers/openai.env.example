# OpenAI 风格 provider 示例
# 复制为 providers/openai.env 后填写真实值。

# 必填。provider 唯一 id，会出现在路由里：/openai/v1/*
PROVIDER_ID=openai

# 必填。是否启用这个 provider。
PROVIDER_ENABLED=true

# 可选。若启用旧版 /v1/* 兼容路由，最多只能有一个 provider 标记为默认。
PROVIDER_IS_DEFAULT=false

# 必填。上游 Responses 兼容接口的基础地址。
# 代理会在这个地址后拼接 /responses 和 /models。
UPSTREAM_BASE_URL=https://example-openai-provider.com/v1

# 必填（除非调用方总是自己传 X-Upstream-Authorization）。
UPSTREAM_API_KEY=

# 可选。这个 provider 对外暴露哪些协议能力。
SUPPORTS_CHAT=true
SUPPORTS_RESPONSES=true
SUPPORTS_MODELS=true
SUPPORTS_ANTHROPIC_MESSAGES=false

# 可选。provider 级模型映射。
# 语义：公共模型名 -> 实际转发给上游的模型名。
# 这里只是示例，真正解析会在后续模型映射分支实现。
# MODEL_MAP_JSON={"gpt-5":"gpt-5.4"}

# 可选。provider 级 reasoning 后缀开关。
# 开启后，-low / -medium / -high / -xhigh 会先被解析，再做模型映射。
# ENABLE_REASONING_EFFORT_SUFFIX=false

# 可选。是否在 /models 中直接展示扩展后的后缀模型名。
# 只有当 ENABLE_REASONING_EFFORT_SUFFIX=true 时，这个开关才有意义。
# 例如会额外展示 gpt-5-low / gpt-5-medium / gpt-5-high / gpt-5-xhigh。
# EXPOSE_REASONING_SUFFIX_MODELS=false
