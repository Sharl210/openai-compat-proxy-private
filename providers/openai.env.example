# ==============================
# provider 运行时配置模板
# ==============================
#
# 复制为 providers/<provider-id>.env 后填写真实值。
# 运行时会监听 providers/ 下真实的 *.env，并忽略 *.env.example。
# 新增 provider 文件时，只有整份配置快照校验成功后才会被加入运行时。
#
# 这个文件中的字段当前都支持热加载。
# 当前 provider 的 Cache_Info 统计快照会统一写到
# 根 .env 中 <PROVIDERS_DIR>/Cache_Info/SYSTEM_JSON_FILES/ 目录下。
# 读取历史统计时，仍兼容旧的 Cache_Info/*.json 落盘位置。

# ========== 基础信息 ==========
# provider 唯一 id。
# 会出现在路由里：/{providerId}/v1/*
PROVIDER_ID=openai

# 是否启用这个 provider。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
PROVIDER_ENABLED=true

# ========== 上游连接 ==========
# 上游基础地址。
# 它只表示这个 provider 对接的上游站点根地址，不决定代理内部最终走哪种正规协议。
UPSTREAM_BASE_URL=https://example-provider.com/v1

# 这个 provider 的默认上游鉴权 key。
# 如果调用方总是自己传 X-Upstream-Authorization，也可以留空。
# 对 Anthropic / Claude 风格客户端，如果当前路由实际不要求代理鉴权，
# 下游的 X-API-Key / x-api-key 也可以直接作为上游 key 使用。
UPSTREAM_API_KEY=

# 当前 provider 内部统一使用的上游协议类型。
# responses：上游走 OpenAI /responses
# chat：上游走 OpenAI /chat/completions
# anthropic：上游走 Anthropic /messages
# 这个字段只决定代理内部请求哪种正规上游协议；
# 不影响对外暴露的 /v1/responses、/v1/chat/completions、/v1/messages 三个公开端口。
UPSTREAM_ENDPOINT_TYPE=responses

# OpenAI 协议上游服务层级覆写。
# 仅当当前 provider 的 UPSTREAM_ENDPOINT_TYPE=responses 或 chat 时才生效。
# 留空表示不自动携带，由下游自己传 service_tier / serviceTier，代理不做修改。
# 填了以后会忽略下游传入的服务层级参数，一律以这里的值发往 OpenAI 上游。
# 可选值：auto、default、flex、priority。
# Fast 模式即指 priority。
# 写成非法值时，这份 provider 配置不会通过校验。
OPENAI_SERVICE_TIER=

# provider 级上游最大输出 token 数。
# 留空表示继承根 .env 的 UPSTREAM_MAX_OUTPUT_TOKENS；根 .env 也留空时，继续使用客户端请求里的 max_tokens / max_output_tokens，或上游协议构造层自己的默认值。
# 支持三种写法：
#   1. 单个默认值，例如 64000
#   2. 默认值 + 精确模型覆写，例如 64000,gpt-5.5:128000
#   3. 默认值 + 精确模型 + 正则覆写，例如 64000,gpt-5.5:128000,#re:.*gpt-.*:100000
# 匹配规则：
#   - 按客户端请求给代理层的完整模型名做字面量/正则匹配。
#   - 不按 MODEL_MAP 映射后的上游模型名匹配，也不会自动剥离 reasoning suffix 或 -noprompt 后缀。
#   - 精确模型匹配优先于正则匹配。
#   - 没有任何 scoped 规则命中时，回落到默认值。
#   - 如果只写 scoped 规则、不写默认值，则未命中任何规则时视为“不设置 provider 默认值”。
# 例如 MODEL_MAP=gpt-5.5:claude-sonnet-4-5 时，客户端请求 gpt-5.5 应写 UPSTREAM_MAX_OUTPUT_TOKENS=gpt-5.5:128000；写 claude-sonnet-4-5:128000 不会命中这个客户端请求。
# 这个字段控制的是发给上游的输出上限请求参数 max_tokens / max_output_tokens，不是上下文窗口大小。
# 填入正整数后，只有当客户端请求没有携带输出上限时，代理才会自动补这个值。
# 填入 -1 表示代理主动不携带最大输出 token 字段；客户端没传时会直接省略，强制开关开启时会忽略客户端传值并省略。
# 当 UPSTREAM_ENDPOINT_TYPE=anthropic 且启用 MAP_REASONING_SUFFIX_TO_ANTHROPIC_THINKING 时，最终命中的正整数值也会参与 thinking budget 计算。
# scoped 规则里的 value 同样必须是正整数或 -1；写成 0、小于 -1 或非整数时，这份 provider 配置不会通过校验。
# 这个字段当前支持热加载。
UPSTREAM_MAX_OUTPUT_TOKENS=

# 是否强制使用 provider 级上游最大输出 token 数。
# 留空表示继承根 .env 的 FORCE_UPSTREAM_MAX_OUTPUT_TOKENS；显式 true / false 时覆盖根配置。
# false：只在客户端请求没有携带 max_tokens / max_output_tokens 时补 UPSTREAM_MAX_OUTPUT_TOKENS。
# true：只要 UPSTREAM_MAX_OUTPUT_TOKENS 已设置，就忽略客户端请求里的输出上限，强制使用 provider 配置值；如果该值是 -1，则最终不携带最大输出 token 字段。
# 如果 UPSTREAM_MAX_OUTPUT_TOKENS 留空，这个开关不会单独生效。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
# 这个字段当前支持热加载。
FORCE_UPSTREAM_MAX_OUTPUT_TOKENS=

# provider 级模型上下文窗口限制。
# 留空表示继承根 .env 的 MODEL_LIMIT_CONTEXT_TOKENS；显式写正整数、scoped 规则或 -1 时覆盖根配置。
# -1 表示代理层不主动限制上下文；真实上游自己的上下文限制仍然照常生效。
# 正整数表示代理按请求内容估算输入 token，超过该值时直接模拟 context_length_exceeded / prompt is too long，便于 OpenCode 等客户端触发自动压缩。
# 支持 scoped 写法，例如 MODEL_LIMIT_CONTEXT_TOKENS=-1,gpt-5.5:400000,#re:.*gpt-.*:256000。
# 匹配规则与 UPSTREAM_MAX_OUTPUT_TOKENS 一致：按客户端请求给代理层的完整模型名匹配，精确模型优先于正则匹配。
# 它不按 MODEL_MAP 映射后的上游模型名匹配，也不会自动剥离 reasoning suffix 或 -noprompt 后缀。
# 例如 MODEL_MAP=gpt-5.5:claude-sonnet-4-5 时，客户端请求 gpt-5.5 应写 MODEL_LIMIT_CONTEXT_TOKENS=gpt-5.5:400000；写 claude-sonnet-4-5:400000 不会命中这个客户端请求。
# 如果客户端请求 gpt-5.5-high，则需要写 gpt-5.5-high:200000 这类完整模型名规则；gpt-5.5:400000 不会自动匹配 gpt-5.5-high。
# 这个字段限制的是代理估算的输入上下文窗口，用于提前模拟 prompt is too long；它和 UPSTREAM_MAX_OUTPUT_TOKENS 控制的输出上限参数互不冲突。
# 这个字段当前支持热加载。
MODEL_LIMIT_CONTEXT_TOKENS=

# 上游 thinking/reasoning 标签格式。
# 只有当 UPSTREAM_ENDPOINT_TYPE=chat 时才生效。
# 必须写成合法布尔值：
#   - true：把 <think>...</think> 或 <thinking>...</thinking> 从正文拆出来，当作思考内容处理。
#   - false：完全不处理任何 think 标签，正文原样透传。
# 这个字段当前支持热加载。
UPSTREAM_THINKING_TAG_STYLE=false

# 上游 XML 工具调用兼容模式。
# 只有当 UPSTREAM_ENDPOINT_TYPE=chat 时才生效。
# 必须写成合法布尔值：
#   - true：把完整的 <tool_call><function=...><parameter=...>...</parameter></function></tool_call> 文本恢复成结构化工具调用。
#   - false：完全不处理 XML 工具调用文本，正文原样透传。
# 这个开关只用于兼容少数会把工具调用退化成 XML 正文的上游；默认 true。
# 这个字段当前支持热加载。
UPSTREAM_XML_TOOL_CALL_STYLE=true

# provider 级代理鉴权覆写。
# 留空表示继承根 .env 里的 PROXY_API_KEY。
# 设置普通值后，这个 provider 的显式分组路由只接受自己的 key。
# 如果值写成 empty，则这个 provider 不需要代理鉴权。
# 对默认 provider 来说，裸 /v1/* 仍然允许使用根 PROXY_API_KEY 访问；
# 但它自己的 /{providerId}/v1/* 路由优先走这里的覆写值。
# provider 作用域请求状态查询 /{providerId}/v1/requests/{requestId} 始终不做鉴权，不受这里影响。
PROXY_API_KEY_OVERRIDE=

# ========== Provider 能力 ==========
# 是否支持 OpenAI Chat Completions 兼容接口。
# 这是弱语义开关，只控制 chat/completions 这个公开端口是否开放。
# 不表示内部实现不能复用别的底层能力。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
SUPPORTS_CHAT=true

# 是否支持 OpenAI /responses。
# 这是弱语义开关，只控制 /responses 这个公开端口是否开放。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
SUPPORTS_RESPONSES=true

# 是否支持 /models。
# 这是弱语义开关，只控制 /models 这个公开端口是否开放。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
SUPPORTS_MODELS=true

# 是否支持 Anthropic /messages 兼容接口。
# 这是弱语义开关，只控制 /messages 这个公开端口是否开放。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
SUPPORTS_ANTHROPIC_MESSAGES=true

# responses 上游工具类型兼容模式。
# 只在当前 provider 的 UPSTREAM_ENDPOINT_TYPE=responses 时才生效。
# preserve：保留原始工具类型（custom / web_search / function），原样发给 responses 上游（默认）。
# function_only：将 custom 和 web_search 工具在发往 responses 上游前重写成普通 function 类型，以兼容不支持这些工具类型的上游。
# 代价说明：
#   - custom 变成 function 后，会丢失原生 free-form / grammar 约束语义。
#   - web_search 变成 function 后，会丢失原生 citations / sources / agentic search 语义。
# 留空时使用默认值 preserve；非法值会让这份 provider 配置校验失败。
# 这个字段当前支持热加载。
RESPONSES_TOOL_COMPAT_MODE=preserve

# Anthropic 协议版本（仅当 UPSTREAM_ENDPOINT_TYPE=anthropic 且上游为 Anthropic 协议时生效）。
# 通常使用 Anthropic 官方推荐值，默认 2023-06-01；留空时会回退为该默认值。
# 代理对下游 /v1/messages 的 anthropic-version 兼容头当前只校验"存在且非空"；
# 这里控制的是代理真正发往 Anthropic 上游的版本值。
ANTHROPIC_VERSION=2023-06-01

# ========== 上游安全门 ==========
# 上游请求的最后一道安全门重试次数。
# 这是"额外重试几遍"，不是总请求次数。
# 默认 5，表示首次请求失败后，最多再重试 5 遍。
# 必须是大于等于 0 的整数；写成非法值时，这份 provider 配置不会通过校验，也不会静默回退到默认值。
# 只在"上游刚请求就失败、还没有收到任何上游数据"时触发。
# 一旦已经收到上游首个 event / chunk，后续中途报错不会再自动重试。
UPSTREAM_RETRY_COUNT=5

# 上游请求安全门的每次重试间隔。
# 默认 5s。
# 必须是 Go duration 格式，且不能为负数；写成非法值时，这份 provider 配置不会通过校验，也不会静默回退到默认值。
# 当所有重试都失败时，代理会在最终返回给客户端的上游错误前加上一句重试说明。
UPSTREAM_RETRY_DELAY=5s

# provider 级首字节超时。
# 留空表示继承根 .env 里的 FIRST_BYTE_TIMEOUT。
# 默认继承根级 30m；如果某个 provider 思考特别久，可以单独放大。
# 必须是合法的 Go duration，且必须大于 0；写成非法值时，这份 provider 配置不会通过校验。
UPSTREAM_FIRST_BYTE_TIMEOUT=

# ========== 下游策略 ==========
# provider 级下游非流模式覆写。
# 留空表示继承根 .env 里的 DOWNSTREAM_NON_STREAM_STRATEGY。
# proxy_buffer：下游非流时，代理继续向上游请求 SSE，再本地聚合。
# upstream_non_stream：下游非流时，代理直接向上游请求非流式 JSON。
DOWNSTREAM_NON_STREAM_STRATEGY_OVERRIDE=

# ========== 系统提示词 ==========
# provider 级系统提示词文件列表。
# 使用逗号分隔多个路径；路径相对于当前 provider .env 文件所在目录。
# 留空表示关闭注入。
# 模板默认写 prompt.md，并建议配一个空文件，这样默认效果等同于关闭。
SYSTEM_PROMPT_FILES=prompt.md

# provider 级系统提示词的拼接位置。
# prepend：拼到用户请求系统提示词前面。
# append：拼到用户请求系统提示词后面。
# 留空或非法值会回退为 prepend。
SYSTEM_PROMPT_POSITION=prepend

# ========== 模型映射 ==========
# provider 级模型映射，格式为逗号分隔的 src:target 对。
# 留空表示不做模型映射。
# 格式示例：MODEL_MAP=gpt-4.1:gpt-4.1-mini,#re:gpt-4(.*):gpt-o1-$1,#re:o3-mini.*:o3-mini
# src（冒号左侧）说明：
#   默认按字面量精确匹配，所以 gpt-4.1 里的点就是普通点，不需要写成 gpt-4\.1。
#   只有以 #re: 开头时才使用 Go regexp，并按全字符串匹配处理。
#   #re: 里支持 Go regexp 的 ^ / $ 锚点；这里的 $ 是正则结尾锚点，不是 target 里的 $1 捕获替换。
#   正则兜底匹配写成 #re:.*；单独 * 不是合法 regexp。
#   #re: 后面的正则转义完全按 Go regexp 处理，例如 #re:gpt-4\*mini 匹配字面星号。
# target（冒号右侧）占位符说明：
#   $0：完整原始模型名
#   $1：#re:src 中第 1 个 regexp 捕获组内容
#   $2-$9：#re:src 中第 2 到第 9 个 regexp 捕获组内容
#   $10 及以上不会展开，会保留为字面值，避免 $12 表示第 12 组还是 $1 后接 2 的歧义
#   例如 #re:mini(.*)o:real-$0-$1 会把 mini2o 映射为 real-mini2o-2
# 转义说明：
#   #re:src 使用标准 Go regexp 转义；target 中如果需要真实的 $，用反斜杠转义：\$，例如 \$12 会输出字面 $12。
# 匹配顺序：
#   1. 按配置顺序依次尝试 src；无 #re: 时为字面量，有 #re: 时为 regexp
#   2. 请求模型带 suffix 时，先用带 suffix 的 key 尝试匹配
#   3. 请求模型带 suffix 时，再用去掉 suffix 后的 base model 尝试匹配
#   4. 如果显式 key 命中了 gpt-5.5-high 这类带 suffix 的模型，它优先于 ENABLE_REASONING_EFFORT_SUFFIX 的自动剥离逻辑
# MODEL_MAP 的 src 和 target suffix 语义相互独立：src suffix 决定客户端请求如何命中映射，target suffix 只在最终上游模型名解析阶段作为 effort 来源。
# 例如 MODEL_MAP=client-gpt:upstream-gpt 时，客户端请求 client-gpt-high 如果 suffix 解析启用，会先剥成 client-gpt 命中映射，上游模型仍是 upstream-gpt，最终 effort 是 high。
# 例如 MODEL_MAP=client-gpt:upstream-gpt-low 时，客户端请求 client-gpt 会映射到 upstream-gpt，最终 effort 是 low；如果客户端请求 client-gpt-high，客户端侧 high 优先，最终 effort 是 high。
# 例如 MODEL_MAP=client-gpt-high:upstream-gpt 时，只有完整请求 client-gpt-high 才直接命中这条显式 src 规则，target 不带 suffix，所以上游模型是 upstream-gpt，effort 来自客户端的 high。
# MODEL_MAP 只负责请求时映射，不会自动把 src 或 target 暴露到 /models。
# 例如 MODEL_MAP=client-gpt:gpt-5.5 后，/models 不会出现 client-gpt；如果要展示它，需要同时写 MANUAL_MODELS=client-gpt。
MODEL_MAP=

# 手动添加或筛选的模型列表（逗号分隔）。
# 静态模型名用于补充 /models 可见模型，例如 MANUAL_MODELS=gpt-4.1,gpt-4o-mini。
# 如果某个 MODEL_MAP alias 需要对客户端可见，也必须在这里显式列出，例如 MODEL_MAP=client-gpt:gpt-5.5 且 MANUAL_MODELS=client-gpt。
# 静态模型名也可以直接写代理层后缀，例如 MANUAL_MODELS=gpt-5.5-noprompt，用来把这个字面模型暴露到 /models；
# 但它仍会按 ENABLE_NOPROMPT_MODEL_SUFFIX 的有效值决定请求时是否剥离 -noprompt。
# #re: pattern 会从上游 /models 列表里匹配扩展，例如上游有 1、2、2.4、5 时，MANUAL_MODELS=#re:2.* 只暴露 2 和 2.4。
# #reason_suffix:model 会为这个 base model 单独生成推理后缀家族，例如 #reason_suffix:gpt-5.5 会暴露
# gpt-5.5、gpt-5.5-none、gpt-5.5-minimal、gpt-5.5-low、gpt-5.5-medium、gpt-5.5-high、gpt-5.5-xhigh。
# #reason_suffix 可以和 #re: 组合，但顺序必须是 #reason_suffix:#re:<pattern>；先写 #re:#reason_suffix:... 不作为合法组合。
# 组合后的 #re: 只从上游 /models 返回的原始模型列表里筛选 base model，不匹配代理层生成的模型、MODEL_MAP alias 或其它手动静态模型。
# #reason_suffix:-minimal 表示只为可见 base model 手动补出 -minimal 档位；其它档位不会因此出现。
# 如果上游 /models 不可用，#re: pattern 不会作为字面模型名暴露；只有静态模型名会参与 fallback。
# 如果同时开启了 ENABLE_REASONING_EFFORT_SUFFIX，最终可见模型也会被暴露带推理后缀的变体。
# 极端情况：当 ENABLE_REASONING_EFFORT_SUFFIX=false，且 MANUAL_MODELS 同时写了 #reason_suffix:gpt-5.5 和字面 gpt-5.5-low，
# gpt-5.5-low 会按字面模型处理；当 ENABLE_REASONING_EFFORT_SUFFIX=true 时，同名 suffix 仍按可解析推理后缀处理。
MANUAL_MODELS=

# 手动隐藏的模型名列表（逗号分隔）。默认按字面量精确匹配；以 #re: 开头时按 Go regexp 全字符串匹配。
# 用于从当前 provider 的 /models 可见列表里移除模型，典型场景是默认分组 overlay 下屏蔽高优先级 provider 的部分模型。
# 这些规则会同时影响：
#   1. 默认分组 bare /v1/models 的聚合结果
#   2. 默认分组 bare /v1/chat/completions、/v1/responses、/v1/messages 的模型准入与分发
#   3. 显式 /{providerId}/v1/models 的可见模型列表
#   4. 显式 /{providerId}/v1/chat/completions、/v1/responses、/v1/messages 的模型准入
# 如果同时开启了 EXPOSE_REASONING_SUFFIX_MODELS，这里的隐藏规则也会作用到 suffix 变体。
# 也可以直接隐藏 -noprompt 变体，例如 HIDDEN_MODELS=gpt-5.5-noprompt，用作禁用该 noprompt 入口的手段。
# 也支持 #reason_suffix:model 这种 family marker，例如 HIDDEN_MODELS=#reason_suffix:gpt-5.5 会隐藏整组推理后缀家族。
# 优先级：静态 MANUAL_MODELS 显式添加最高；例如 MANUAL_MODELS=gpt-5.5-noprompt 时，
# 即使 HIDDEN_MODELS 也写了 gpt-5.5-noprompt，这个字面模型仍会显示。
# 特例：#reason_suffix:model 是批量生成推理后缀家族，不等同于每个档位都被静态手动添加；
# HIDDEN_MODELS 仍可以隐藏其中某个具体档位，例如 HIDDEN_MODELS=gpt-5.5-minimal。
# 如果 MANUAL_MODELS 和 HIDDEN_MODELS 同时写同一个 #reason_suffix:model，手动添加优先，最终仍显示。
# 粒度优先，其次手动优先：手动大范围 family 遇到隐藏小范围档位时，隐藏小范围优先；
# 手动和隐藏同一范围时，手动优先；隐藏是大范围 family 而手动是小范围字面模型时，手动小范围优先。
# HIDDEN_MODELS=#reason_suffix:-minimal 表示隐藏所有可见 base model 的 -minimal 档位。
# 对 ENABLE_REASONING_EFFORT_SUFFIX / EXPOSE_REASONING_SUFFIX_MODELS 这类全局后缀开关来说，HIDDEN_MODELS 始终是更细粒度限制；
# 即使全局开启了 suffix 解析或展示，HIDDEN_MODELS 仍可以隐藏具体档位、具体模型档位或整组 family。
# 注意：#re: 是普通 Go regexp，不理解 suffix 语义边界；#re:.*mini.* 也会匹配 gpt-5.5-minimal。
# 如果只想隐藏 mini 模型而保留 -minimal 推理强度，请使用更精确的正则或直接列出字面模型名。
# 例如：HIDDEN_MODELS=#re:gpt-4.*,claude-3.7-sonnet-high
HIDDEN_MODELS=

# 是否启用模型名 -noprompt 后缀跳过本 provider 的 SYSTEM_PROMPT_FILES 注入。
# 留空：继承根 .env 的 ENABLE_NOPROMPT_MODEL_SUFFIX。
# true / false：覆盖根配置；false 时客户端带 -noprompt 也不会剥离，透明度响应头会显示 X-Client-To-Proxy-NoPrompt=false。
# HIDDEN_MODELS 可以隐藏具体 -noprompt 变体，作为对单个模型禁用 noprompt 的手段。
ENABLE_NOPROMPT_MODEL_SUFFIX=

# ========== 推理强度 ==========
# 是否把 -none / -minimal / -low / -medium / -high / -xhigh 这类模型后缀解析成 reasoning effort。
# -none 表示关闭推理；Anthropic 上游会映射为 thinking disabled，OpenAI 风格上游会显式携带 none。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
ENABLE_REASONING_EFFORT_SUFFIX=false

# /models 是否额外暴露带 suffix 的模型名。
# 只有 ENABLE_REASONING_EFFORT_SUFFIX=true 时这个开关才有意义。
# 这个开关只控制模型列表展示，不影响客户端显式请求 model-high / model-medium 这类 suffix 模型。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
EXPOSE_REASONING_SUFFIX_MODELS=false

# 是否在 Anthropic 上游场景下，把解析出来的 reasoning suffix 自动映射为上游 thinking 配置。
# 只有同时满足以下条件时才会生效：
#   1. ENABLE_REASONING_EFFORT_SUFFIX=true
#   2. 当前 provider 的 UPSTREAM_ENDPOINT_TYPE=anthropic
# reasoning suffix 优先级高于客户端请求体里的 reasoning / thinking 设置；例如 model-low 会覆盖客户端传入的 thinking disabled。
# 当前策略：优先给支持的模型发送 adaptive thinking + effort；其余模型再按 max_tokens 比例回退到 budget_tokens。
# 裸 Anthropic adaptive thinking 转到非 Anthropic 上游时，会按 xhigh 映射成 OpenAI 风格 reasoning。
# 默认 false，避免偷偷改变已有请求语义。
# 必须写成合法布尔值；非法值会让这份 provider 配置校验失败。
MAP_REASONING_SUFFIX_TO_ANTHROPIC_THINKING=false

# ========== 伪装相关 ==========
# 上游请求时使用的自定义 User-Agent 头（provider 级）。
# 这是一个完全独立的字段，与伪装目标 MASQUERADE_TARGET 不沾边；
# 优先级高于伪装目标对 User-Agent 的修改（即：如果设置了，伪装目标的 User-Agent 被覆盖）。
# 其他伪装档专属头（originator / X-App 等）不受此字段影响，仍由 MASQUERADE_TARGET 决定。
# 留空表示不设置（但仍以伪装目标 MASQUERADE_TARGET 的 User-Agent 为准）。
UPSTREAM_USER_AGENT=

# 伪装目标客户端标识，优先级高于根 .env 的 UPSTREAM_MASQUERADE_TARGET。
# 语义说明：
#   - 留空：继承上层（根 .env）配置。
#   - none：显式禁用伪装（不等效于"继承"，是主动关掉）。
#   - opencode / claude / codex：启用对应伪装档。
# 优先级说明：
#   UPSTREAM_USER_AGENT（自定义 UA）始终覆盖伪装目标对 User-Agent 的修改，
#   但不改变其他伪装档专属头（originator / X-App 等）。
# 可选值及效果：
#   opencode：发送 User-Agent: opencode/1.16.2 ai-sdk/provider-utils/4.0.27 runtime/bun/1.3.14
#            + originator: opencode
#            适用于绕过 sub2api 对 originator 前缀的校验。
#   claude：  发送 User-Agent: claude-cli/2.1.167 (external, cli) + X-App: cli
#            + anthropic-beta: claude-code-20250219,oauth-2025-04-20,interleaved-thinking-2025-05-14,
#              prompt-caching-scope-2026-01-05,effort-2025-11-24,context-management-2025-06-27,
#              extended-cache-ttl-2025-04-11
#            + X-Stainless-* 等完整 Claude Code 头。
#            适用于 /messages 路径，配合下方的 INJECT_CLAUDE_CODE_* 使用。
#   codex：   发送 User-Agent: codex_cli_rs/0.137.0 (Linux 6.1; x86_64) iTerm.app
#            + originator: codex_cli_rs + x-openai-internal-codex-residency: us。
#            + 当请求带 reasoning 时自动补 include=reasoning.encrypted_content。
#            适用于绕过 sub2api 对 codex_cli_rs/ 前缀的校验，并更贴近真实 Codex CLI 请求形态。
#   none：    显式禁用伪装，不注入任何伪装 header。
MASQUERADE_TARGET=

# 是否向上游 Anthropic 请求体中注入 metadata.user_id。
# 仅在本层或继承上层的有效伪装目标为 claude 时才生效。
# 用于 Claude Code 伪装档绕过 sub2api 的 metadata.user_id 格式校验。
# 留空表示继承根 .env 的 UPSTREAM_INJECT_METADATA_USER_ID。
# 显式写 true / false 表示覆盖根级配置；必须写成合法布尔值。
INJECT_CLAUDE_CODE_METADATA_USER_ID=

# 是否向上游 Anthropic 请求体中注入 Claude Code 真实 system prompt。
# 仅在本层或继承上层的有效伪装目标为 claude 时才生效。
# 用于 Claude Code 伪装档绕过 sub2api 的 system prompt Dice 系数相似度校验。
# 留空表示继承根 .env 的 UPSTREAM_INJECT_CLAUDE_SYSTEM_PROMPT。
# 显式写 true / false 表示覆盖根级配置；必须写成合法布尔值。
INJECT_CLAUDE_CODE_SYSTEM_PROMPT=
