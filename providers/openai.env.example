# 通用 provider 示例
# 复制为 providers/<你的-provider-id>.env 后填写真实值。

# 必填。provider 唯一 id，会出现在路由里：/<providerId>/v1/*
PROVIDER_ID=openai

# 必填。是否启用这个 provider。
PROVIDER_ENABLED=true

# 必填。上游 Responses 兼容接口基础地址。
# 无论对外是 Anthropic、OpenAI Responses，还是 OpenAI Chat Completions（兼容接口），
# 这个项目当前都会统一转发到上游 /responses。
UPSTREAM_BASE_URL=https://example-provider.com/v1

# 必填（除非调用方总是自己传 X-Upstream-Authorization）。
UPSTREAM_API_KEY=

# 可选。这个 provider 对外暴露哪些协议能力。
SUPPORTS_CHAT=true
SUPPORTS_RESPONSES=true
SUPPORTS_MODELS=true
SUPPORTS_ANTHROPIC_MESSAGES=true

# 可选。provider 级模型映射。
# 语义：请求模型名 -> 实际转发给上游的模型名。
# ENABLE_REASONING_EFFORT_SUFFIX 开启后，key 和 value 都可以写推理等级后缀。
# effort 最终以 value 的后缀为准（value 有后缀则用 value 的，无则空）。
# 匹配顺序：*-suffix 通配 key（优先） → 精确 key → strip 后缀后精确 key → * 通配 key。
# 开关关闭时：后缀只做字符串替换，不解析 effort。
# 例子（开关开启）：
# MODEL_MAP_JSON={"gpt-4o-high":"vendor-gpt-4o"}         → gpt-4o-high → vendor-gpt-4o，effort=""
# MODEL_MAP_JSON={"gpt-4o-high":"vendor-gpt-4o-high"}   → gpt-4o-high → vendor-gpt-4o-high，effort="high"
# MODEL_MAP_JSON={"*-high":"vendor-default"}             → 所有 *-high → vendor-default，effort=""
# MODEL_MAP_JSON={"*-high":"vendor-default-high"}        → 所有 *-high → vendor-default-high，effort="high"
# MODEL_MAP_JSON={"gpt-4o":"vendor-gpt-4o"}             → gpt-4o-high → vendor-gpt-4o，effort="high"
# MODEL_MAP_JSON={"*":"vendor-default"}                  → 任意 → vendor-default，effort=""
# MODEL_MAP_JSON={"*":"vendor-default-high"}            → 任意 → vendor-default-high，effort="high"
# 例子（开关关闭）：MODEL_MAP_JSON={"gpt-4o-high":"vendor-gpt-4o"} → gpt-4o-high → vendor-gpt-4o，无 effort

# 可选。开启后解析推理等级后缀。
# 关闭时后缀作为普通模型名处理。
# ENABLE_REASONING_EFFORT_SUFFIX=false

# 可选。/models 中是否额外展示带后缀的模型名。
# 前提：ENABLE_REASONING_EFFORT_SUFFIX=true。
# EXPOSE_REASONING_SUFFIX_MODELS=false
